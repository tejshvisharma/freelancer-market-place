    {
      "name": "2. Email Verification",
      "item": [
        {
          "name": "2.1 Get Verification Token from Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Note: You need to manually get the verification token from the email",
                  "// Check your Ethereal inbox at https://ethereal.email/",
                  "// Or check your actual email if using production email",
                  "",
                  "pm.test('This is a manual step reminder', () => {",
                  "    console.log('⚠️ MANUAL STEP REQUIRED:');",
                  "    console.log('1. Check your email for verification link');",
                  "    console.log('2. Copy the token from the URL');",
                  "    console.log('3. Set it as verification_token in environment');",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://ethereal.email/messages",
              "host": ["https://ethereal.email"],
              "path": ["messages"],
              "query": [
                {
                  "key": "note",
                  "value": "Check your verification email here"
                }
              ]
            }
          }
        },
        {
          "name": "2.2 Verify Email (Replace Token Manually)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 Success', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Email should be verified', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data.verified).to.be.true;",
                  "    pm.expect(response.success).to.be.true;",
                  "});",
                  "",
                  "console.log('Email verified successfully');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify-email/{{verification_token}}",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email", "{{verification_token}}"],
              "variable": [
                {
                  "key": "verification_token",
                  "value": "REPLACE_WITH_ACTUAL_TOKEN_FROM_EMAIL"
                }
              ]
            }
          }
        },
        {
          "name": "2.3 Verify with Invalid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 400 Bad Request', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Should mention invalid/expired token', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.message.toLowerCase()).to.match(/invalid|expired/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify-email/invalid-token-123",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email", "invalid-token-123"]
            }
          }
        },
        {
          "name": "2.4 Resend Verification Email (Authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 Success', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Note: If email is already verified, this might fail with 400",
                  "const response = pm.response.json();",
                  "if (response.statusCode === 400) {",
                  "    console.log('Email already verified - expected behavior');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/resend-verification",
              "host": ["{{base_url}}"],
              "path": ["auth", "resend-verification"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Login Flow",
      "item": [
        {
          "name": "3.1 Login with Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 OK', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Should contain user data and tokens', () => {",
                  "    pm.expect(response.data).to.have.property('user');",
                  "    pm.expect(response.data).to.have.property('accessToken');",
                  "    pm.expect(response.data.user.email).to.eql(pm.environment.get('user_email'));",
                  "});",
                  "",
                  "// Update tokens",
                  "pm.environment.set('access_token', response.data.accessToken);",
                  "pm.environment.set('user_id', response.data.user.id);",
                  "",
                  "// Check for refresh token in cookies",
                  "const cookies = pm.response.headers.get('Set-Cookie');",
                  "if (cookies) {",
                  "    console.log('Refresh token cookie set');",
                  "}",
                  "",
                  "console.log('Login successful for:', response.data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "3.2 Login with Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 401 Unauthorized', () => {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Should have invalid credentials message', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.false;",
                  "    pm.expect(response.message.toLowerCase()).to.include('invalid');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"WrongPassword@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "3.3 Login with Non-Existent Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 401 Unauthorized', () => {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "// Security: Message should be same as wrong password",
                  "pm.test('Should not reveal if email exists', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.message.toLowerCase()).to.include('invalid');",
                  "    pm.expect(response.message).to.not.include('not found');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"nonexistent@example.com\",\n    \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "3.4 Login Rate Limiting Test (Send Multiple Times)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// This test is meant to be run multiple times quickly",
                  "// After 5 failed attempts, should return 429",
                  "",
                  "const statusCode = pm.response.code;",
                  "",
                  "if (statusCode === 429) {",
                  "    pm.test('Rate limiting works - 429 Too Many Requests', () => {",
                  "        pm.expect(statusCode).to.eql(429);",
                  "    });",
                  "    console.log('✅ Rate limiting is working');",
                  "} else if (statusCode === 401) {",
                  "    console.log('⚠️ Keep sending requests to trigger rate limit (sent from Postman Runner)');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"wrong_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
