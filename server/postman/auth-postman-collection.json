        {
          "name": "6.2 Reset Password (Replace Token Manually)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 200 OK', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.test('Should provide new access token', () => {",
                  "    pm.expect(response.data).to.have.property('accessToken');",
                  "});",
                  "",
                  "// Update token",
                  "if (response.data.accessToken) {",
                  "    pm.environment.set('access_token', response.data.accessToken);",
                  "    pm.environment.set('user_password', 'NewPassword@456');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
