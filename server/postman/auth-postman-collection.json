{
  "info": {
    "name": "Auth System Test Suite",
    "description": "Complete authentication flow testing for Freelancer Marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Registration Flow",
      "item": [
        {
          "name": "1.1 Register Client User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test status code",
                  "pm.test('Status should be 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Test response structure",
                  "pm.test('Response should have correct structure', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.true;",
                  "    pm.expect(response.message).to.exist;",
                  "    pm.expect(response.data).to.have.property('user');",
                  "    pm.expect(response.data).to.have.property('accessToken');",
                  "});",
                  "",
                  "// Test user data",
                  "pm.test('User data should be correct', () => {",
                  "    const user = pm.response.json().data.user;",
                  "    pm.expect(user.email).to.eql(pm.environment.get('user_email'));",
                  "    pm.expect(user.role).to.eql('client');",
                  "    pm.expect(user.isEmailVerified).to.be.false;",
                  "});",
                  "",
                  "// Save tokens and user ID",
                  "const response = pm.response.json();",
                  "pm.environment.set('access_token', response.data.accessToken);",
                  "pm.environment.set('user_id', response.data.user.id);",
                  "",
                  "// Log for debugging",
                  "console.log('Client registered successfully');",
                  "console.log('User ID:', response.data.user.id);",
                  "console.log('Email Verified:', response.data.user.isEmailVerified);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{user_name}}\",\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\",\n    \"role\": \"client\",\n    \"phone\": \"+1234567890\",\n    \"location\": \"New York, USA\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.2 Register Freelancer User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status should be 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "pm.test('Freelancer role should be set', () => {",
                  "    pm.expect(response.data.user.role).to.eql('freelancer');",
                  "});",
                  "",
                  "// Save freelancer data for later tests",
                  "pm.environment.set('freelancer_id', response.data.user.id);",
                  "pm.environment.set('freelancer_token', response.data.accessToken);",
                  "",
                  "console.log('Freelancer registered successfully');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{freelancer_name}}\",\n    \"email\": \"{{freelancer_email}}\",\n    \"password\": \"{{user_password}}\",\n    \"role\": \"freelancer\",\n    \"phone\": \"+0987654321\",\n    \"location\": \"San Francisco, USA\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.3 Register with Existing Email (Should Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 409 Conflict', () => {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Should have error message about duplicate', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.success).to.be.false;",
                  "    pm.expect(response.message.toLowerCase()).to.include('exist');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"{{user_name}}\",\n    \"email\": \"{{user_email}}\",\n    \"password\": \"{{user_password}}\",\n    \"role\": \"client\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.4 Register with Invalid Data (Validation Test)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should return 422 Validation Error', () => {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('Should have validation errors array', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.errors).to.be.an('array');",
                  "    pm.expect(response.errors.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
